# Unity 생성 폴더
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emory[Cc]aptures/

# 에셋 메타데이터 (삭제 금지)
!/[Aa]ssets/**/*.meta

# Visual Studio / Rider
.vs/
.idea/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# OS
.DS_Store
Thumbs.db
desktop.ini

# 빌드 결과물
*.apk
*.aab
*.ipa
*.xarchive

# 패키지 캐시
[Pp]ackages/com.unity.*
!/[Pp]ackages/manifest.json
!/[Pp]ackages/packages-lock.json

# Addressables
[Aa]ddressable[Aa]ssets[Ss]ettings/
