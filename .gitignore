# Unity 생성 폴더
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emory[Cc]aptures/

# 에셋 메타데이터 (삭제 금지)
!/[Aa]ssets/**/*.meta

# Visual Studio / Rider
.vs/
.idea/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# OS
.DS_Store
Thumbs.db
desktop.ini

# 빌드 결과물
*.apk
*.aab
*.ipa
*.xarchive

# 패키지 캐시
[Pp]ackages/com.unity.*
!/[Pp]ackages/manifest.json
!/[Pp]ackages/packages-lock.json

# Addressables
[Aa]ddressable[Aa]ssets[Ss]ettings/

# Firebase 대용량 바이너리 (GitHub 100MB 제한 회피)
# Firebase는 Unity Package Manager로 설치 → Library/PackageCache에 자동 저장
# Assets/Firebase는 Unity가 자동 임포트하는 폴더라 빌드 시 다시 생성됨
Assets/Firebase/Plugins/x86_64/*.so
Assets/Firebase/Plugins/x86_64/*.bundle
Assets/Firebase/Plugins/x86_64/*.dll
Assets/Firebase/Plugins/x86_64/*.so.meta
Assets/Firebase/Plugins/x86_64/*.bundle.meta
Assets/Firebase/Plugins/x86_64/*.dll.meta
